							"  return o.idCategoria ?? o.id_categoria ?? o.id ?? (o.data? (o.data.idCategoria ?? o.data.id_categoria ?? o.data.id) : null); }",
							"const newId = pickId(json);",
							"if(newId){ pm.collectionVariables.set('categoriaId', newId); }",
							"pm.test('Guarda categoriaId en variables si existe', function(){ pm.expect(true).to.be.true; });"
						]
